;TESTS.MAC - assembly-level unit tests for nkLisp internals
;
;Built into a separate CP/M binary (tests.com) by linking this module
;FIRST, so its START sits at 0x0100 (the program entry).  nklisp.rel
;is still linked so other modules can reach REVALO/ERR/etc., but
;COLD never runs - we provide our own init below and exit via BDOS 0.
;
;NOTE: this file MUST have CRLF line endings - M80 silently emits no
;code from LF-only sources.  The repo's .gitattributes enforces CRLF
;on *.mac for everyone.

	INCLUDE NKLISP.DEF

	EXTRN MEMTOP,SINIT,HEAPTR,TOOLS
	EXTRN CONS
	EXTRN PR$PC

START::
	;Init the bits of COLD we need (SP, MEMTOP, RST tool table).
	LD HL,(6)		;TOP OF MEMORY (CP/M convention)
	LD (MEMTOP),HL
	LD SP,HL
	LD (SINIT),HL

	;Copy the RST tool table - POPLIST/FETCH/CPDE/CPBC live at
	;RST 08H/18H/20H/28H and are used by most internal routines.
	LD DE,8
	LD HL,TOOLS
	LD BC,40
	LDIR

	CALL TEST_SUITE

	;Exit cleanly.
	LD C,0			;BDOS function 0 = warm boot
	JP 5

;Each test inlined; print '.' on pass, 'F' followed by a digit on fail.
;Driver greps the output for any 'F' to detect failures.
TEST_SUITE::
	PRINT "asm: "

	;TEST 1: HEAPTR is non-zero after init.
	LD HL,(HEAPTR)
	LD A,H
	OR L
	JR Z,TST1FAIL
	LD A,'.'
	CALL CONOUT
	JR TST2
TST1FAIL:
	LD A,'F'
	CALL CONOUT
	LD A,'1'
	CALL CONOUT

TST2:
	;TEST 2: CONS advances HEAPTR by exactly 4 bytes.
	LD HL,(HEAPTR)
	PUSH HL			;save old HEAPTR
	LD HL,0
	LD DE,0
	CALL CONS		;HL = new pair address
	POP BC			;old HEAPTR in BC
	LD HL,(HEAPTR)		;current HEAPTR in HL
	OR A			;clear carry
	SBC HL,BC		;HL = current - old (should be 4)
	LD A,L
	CP 4
	JR NZ,TST2FAIL
	LD A,H
	OR A
	JR NZ,TST2FAIL
	LD A,'.'
	CALL CONOUT
	JR TST3
TST2FAIL:
	LD A,'F'
	CALL CONOUT
	LD A,'2'
	CALL CONOUT

TST3:
	;TEST 3: CONS stores car little-endian, cdr REVERSED (high-then-low).
	;The asymmetric layout lets POPLIST read both halves with one
	;shorter Z80 sequence - see "CDR IN HL (REVERSE)" comment at TOOLS
	;in systab.mac.
	LD HL,1234H		;car: H=12, L=34
	LD DE,5678H		;cdr: D=56, E=78
	CALL CONS		;HL = new pair address
	LD A,(HL)		;byte 0 = car low (L)
	CP 34H
	JR NZ,TST3FAIL
	INC HL
	LD A,(HL)		;byte 1 = car high (H)
	CP 12H
	JR NZ,TST3FAIL
	INC HL
	LD A,(HL)		;byte 2 = cdr HIGH (D)
	CP 56H
	JR NZ,TST3FAIL
	INC HL
	LD A,(HL)		;byte 3 = cdr LOW (E)
	CP 78H
	JR NZ,TST3FAIL
	LD A,'.'
	CALL CONOUT
	JR TST4
TST3FAIL:
	LD A,'F'
	CALL CONOUT
	LD A,'3'
	CALL CONOUT

TST4:
	;TEST 4: SINIT was set during init and equals MEMTOP.
	LD HL,(SINIT)
	LD DE,(MEMTOP)
	OR A
	SBC HL,DE
	LD A,H
	OR L
	JR NZ,TST4FAIL
	LD A,'.'
	CALL CONOUT
	JR DONE
TST4FAIL:
	LD A,'F'
	CALL CONOUT
	LD A,'4'
	CALL CONOUT

DONE:
	PRINT " OK"
	CALL CRLF
	RET

CONOUT::
	LD E,A
	LD C,2
	JP 5

CRLF::
	LD A,13
	CALL CONOUT
	LD A,10
	JP CONOUT

	END
